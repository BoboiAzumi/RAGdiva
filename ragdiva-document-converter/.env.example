# ============================================================
# .env.example — Template environment variables
# ============================================================
# Salin file ini menjadi .env dan sesuaikan nilainya.
# Command: cp .env.example .env
# ============================================================

# ── RABBITMQ CONNECTION ────────────────────────────────────
# Host RabbitMQ (gunakan nama service Docker jika pakai compose)
RABBITMQ_HOST=rabbitmq
# Port default AMQP protocol
RABBITMQ_PORT=5672
# Kredensial RabbitMQ (ganti di production!)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── QUEUE CONFIGURATION ───────────────────────────────────
# Nama queue yang akan di-consume oleh service ini
QUEUE_NAME=document_convert

# ── THREAD POOL ────────────────────────────────────────────
# Jumlah maksimal thread yang berjalan bersamaan untuk konversi
# Semakin banyak = semakin banyak konversi paralel, tapi juga
# semakin banyak resource (CPU/RAM) yang digunakan
MAX_WORKERS=4

# ── RETRY ──────────────────────────────────────────────────
# Jumlah percobaan reconnect ke RabbitMQ jika koneksi gagal
RABBITMQ_RETRY_COUNT=5
# Delay (detik) antara percobaan reconnect
RABBITMQ_RETRY_DELAY=5
