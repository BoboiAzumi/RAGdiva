// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "mysql"
}

model Users {
  id       String @id @default(uuid())
  username String @unique
  password String
  fullName String @map("full_name")
  level    Level

  activityLogs ActivityLogs[]
  majorAccess  MajorAccess[]

  @@map("users")
}

model MajorAccess {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  majorId String @map("major_id")

  majors Majors @relation(fields: [majorId], references: [id])
  users  Users  @relation(fields: [userId], references: [id])

  @@map("major_access")
}

model Majors {
  id            String        @id @unique
  majorName     String        @map("major_name")
  accreditation Accreditation

  criteria      Criteria[]
  majorAccesses MajorAccess[]

  @@map("majors")
}

model Criteria {
  id          String  @id @default(uuid())
  parent      String?
  code        String  @default("")
  name        String  @default("")
  description String  @default("")
  access      String?

  major          Majors?    @relation(fields: [access], references: [id])
  parentCriteria Criteria?  @relation("CriteriaHierarchy", fields: [parent], references: [id])
  childCriteria  Criteria[] @relation("CriteriaHierarchy")
  fileLinks      FileLink[]

  @@map("criteria")
}

model FileLink {
  id           String @id @default(uuid())
  criteriaId   String @map("criteria_id")
  fileId       String @map("file_id")
  criteriaLink String @map("criteria_link")
  page         Int    @default(1)

  files    Files    @relation(fields: [fileId], references: [id])
  criteria Criteria @relation(fields: [criteriaId], references: [id])
}

model Files {
  id        String   @id @default(uuid())
  title     String
  fileName  String   @map("file_name")
  fileHash  String   @unique @map("file_hash")
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")
  updateAt  DateTime @updatedAt @map("update_at")
  status    Status

  activityLogs ActivityLogs[]
  fileLinks    FileLink[]

  @@map("files")
}

model ActivityLogs {
  id        String   @id @default(uuid())
  fileId    String   @map("file_id")
  userId    String   @map("user_id")
  action    Action
  createdAt DateTime @default(now()) @map("created_at")

  users Users @relation(fields: [userId], references: [id])
  files Files @relation(fields: [fileId], references: [id])

  @@map("activity_logs")
}

model AIChatHistory {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  role      String
  content   String @db.LongText

  @@map("ai_chat_history")
}

enum Action {
  Upload
  Delete
  Update
  Rename
  Download

  @@map("action")
}

enum Level {
  Admin
  User
  Asesor
}

enum Status {
  Processing
  Completed
  Reprocessing
  Failed
}

enum Accreditation {
  Unggul
  Baik_Sekali         @map("Baik Sekali")
  Baik
  Tidak_Terakreditasi @map("Tidak Terakreditasi")
}
